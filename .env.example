# Autumn — environment configuration template.
# Copy to `.env` (gitignored) and fill in your provider details.
# Load with: AutumnConfig.from_env(env_file=".env")

# ── A1 (WP1 Tot — orchestration / routing) ─────────────────────────────────
A1_API_KEY=sk-...
A1_BASE_URL=https://api.openai.com
A1_MODEL=gpt-4o-mini
A1_PROTOCOL=openai             # openai | anthropic | hermes

# ── A2 (WP2 Tas — task execution) ──────────────────────────────────────────
A2_API_KEY=sk-...
A2_BASE_URL=https://api.anthropic.com
A2_MODEL=claude-sonnet-4-5
A2_PROTOCOL=anthropic

# ── A3 (WP3 Mis — mission / conversation) ──────────────────────────────────
A3_API_KEY=sk-...
A3_BASE_URL=https://api.openai.com
A3_MODEL=gpt-4o
A3_PROTOCOL=openai

# ── A4 (optional memory model — recall synthesis, cheap/local LLM) ─────────
# Powers the recall/remember skills exposed via Autumn.add_memory_skills().
# Leave A4_API_KEY blank to disable; A4_MODEL must be set when A4_API_KEY is.
# A4_API_KEY=ollama
# A4_BASE_URL=http://localhost:11434
# A4_MODEL=llama3.1:8b
# A4_PROTOCOL=openai             # openai | anthropic | hermes

# ── Hermes (local model via Ollama — alternative to cloud providers) ───────
# A2_API_KEY=ollama
# A2_BASE_URL=http://localhost:11434
# A2_MODEL=hermes3:8b
# A2_PROTOCOL=hermes

# ── Embedding (optional; enables vector memory) ────────────────────────────
# EMBEDDING_API_KEY=sk-...
# EMBEDDING_BASE_URL=https://api.openai.com
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=1536

# ── Runtime ────────────────────────────────────────────────────────────────
STORAGE_DB_PATH=autumn_memory.db
HEADLESS_MISSION_ROUTE=auto    # auto | direct | convert
AUTO_INDEX=false               # true to auto-embed every history entry
VALIDATE_BEFORE_STREAM=true    # false to stream tokens live (checker becomes advisory)

# ── Server (read by `python -m autumn.server`) ─────────────────────────────
# AUTUMN_HOST=127.0.0.1        # bind address; set 0.0.0.0 to expose externally
# AUTUMN_PORT=8765
# AUTUMN_RELOAD=0              # 1 enables uvicorn auto-reload for development
# AUTUMN_ENV_FILE=.env         # which env file the server loads at startup
# AUTUMN_SKIP_INIT=0           # 1 skips Autumn() construction at startup (tests only)
