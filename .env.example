# Autumn — environment configuration template.
# Copy to `.env` (gitignored) and fill in your provider details.
# Load with: AutumnConfig.from_env(env_file=".env")

# ── A1 (WP1 Tot — orchestration / routing) ─────────────────────────────────
A1_API_KEY=sk-...
A1_BASE_URL=https://api.openai.com
A1_MODEL=gpt-4o-mini
A1_PROTOCOL=openai             # openai | anthropic | hermes

# ── A2 (WP2 Tas — task execution) ──────────────────────────────────────────
A2_API_KEY=sk-...
A2_BASE_URL=https://api.anthropic.com
A2_MODEL=claude-sonnet-4-5
A2_PROTOCOL=anthropic

# ── A3 (WP3 Mis — mission / conversation) ──────────────────────────────────
A3_API_KEY=sk-...
A3_BASE_URL=https://api.openai.com
A3_MODEL=gpt-4o
A3_PROTOCOL=openai

# ── Pricing (optional, per slot — USD per 1,000,000 tokens) ────────────────
# Set these to your provider's published rates to get per-turn cost_usd in the
# workflow trace. Any slot can be priced; leave at 0 (omit) to skip.
# A1_INPUT_PRICE=0.15
# A1_OUTPUT_PRICE=0.60
# A2_INPUT_PRICE=3.00
# A2_OUTPUT_PRICE=15.00
# A3_INPUT_PRICE=2.50
# A3_OUTPUT_PRICE=10.00

# ── A4 (optional memory model — drives WP4, the memory-management workspace) ─
# A4 powers WP4: recall synthesis, consolidation summaries, and the
# recall/remember skills exposed via Autumn.add_memory_skills(). Without it,
# WP4 still does the mechanical work (forget/stats/pin) but consolidation 400s.
# Leave A4_API_KEY blank to disable; A4_MODEL must be set when A4_API_KEY is set
# (if A4_API_KEY is set but A4_MODEL is empty, A4 is disabled with a warning).
# A4_API_KEY=ollama
# A4_BASE_URL=http://localhost:11434
# A4_MODEL=qwen2.5:1.5b          # REQUIRED — must be a model the server has pulled
# A4_PROTOCOL=openai             # openai | hermes (NOT anthropic — Ollama uses /v1/chat/completions)
# A4_INPUT_PRICE=0.0             # optional USD/1M tokens for cost tracking
# A4_OUTPUT_PRICE=0.0

# ── Hermes (local model via Ollama — alternative to cloud providers) ───────
# A2_API_KEY=ollama
# A2_BASE_URL=http://localhost:11434
# A2_MODEL=hermes3:8b
# A2_PROTOCOL=hermes

# ── Embedding (optional; enables vector memory) ────────────────────────────
# EMBEDDING_API_KEY=sk-...
# EMBEDDING_BASE_URL=https://api.openai.com
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=1536

# ── Runtime ────────────────────────────────────────────────────────────────
STORAGE_DB_PATH=autumn_memory.db
STORAGE_BACKEND=sqlite         # sqlite (default) | markdown (readable .md per entry, 4D frontmatter)
LEXICAL_RECALL_ENABLED=false   # true to add a BM25/FTS5 keyword layer fused into recall (hybrid)
HEADLESS_MISSION_ROUTE=auto    # auto | direct | convert
AUTO_INDEX=false               # true to auto-embed every history entry
ASYNC_INDEX=false              # true to index in the background (append returns before indexing completes)
VALIDATE_BEFORE_STREAM=true    # false to stream tokens live (checker becomes advisory)

# ── Behavior (optional — tunable knobs; defaults shown) ────────────────────
# AGENT_MAX_STEPS=10           # WP2 Agent ReAct iteration ceiling
# CHECKER_RETRIES=3            # Checker validate→correct attempts before giving up
# CONFIRM_THRESHOLD=0.75       # Selector confidence below which the user is asked
# HISTORY_LIMIT=50             # Per-area memory history entries retained
# ── 0.3.0 cooperative workflow (A1=组长 coordinating A2/A3/A4) ─────────────────
# COOPERATIVE_WORKFLOW=true     # Master switch. false = revert every feature below to 0.2.x behaviour.
# A3_LITE_SKILLS=              # Comma-separated skill names A3 may call on the direct path
#                              # (empty = A3 answers plain; e.g. recall,remember,get_time)
# A1_TASK_PLANNING=false       # A1 generates a step plan before dispatching every TASK to A2
#                              # (adds one A1 call per task; default off to avoid extra latency)
# A1_SUPERVISION=false         # A1 reviews each A2 ReAct step and may inject corrective guidance
#                              # (one A1 call per tool step — costly; default off)
# ARCHIVE_EXECUTIONS=true      # A1 hands each turn's outcome to A4 for a shared-zone execution summary
# A4_DELEGATE_TO_A1=true       # Heavy cognitive memory ops (consolidate/evolve/project discussion)
#                              # use A1 (strong model) instead of A4 (local weak model); default on
# A4_DELEGATION_THRESHOLD=2000 # Min source chars before A4 delegates to A1; smaller ops stay on local A4
# A4_KNOWLEDGE_TERR=false      # Register a web-retrieval Terr and give A4 a research() path over it
# MEMORY_DECAY_HALF_LIFE=0     # Seconds; entry importance halves each interval (0 = off).
#                              # When set, stale low-value memories are evicted before fresh ones.
# FOURD_MEMORY_ENABLED=true    # default true: recall/evict rank by 4D activation score (set false for legacy importance×timestamp)
# FOURD_PUSH_ON_TURN=true      # default true: CONSTRAIN/REMIND memories auto-inject at turn start (set false to disable push)
# MOM1_ACCESS_ENABLED=true     # Mom2/Mom3 may request adjudicated Mom1 reads (A1 gates, A4 mediates).
#                              # false = kill switch: every request is denied without consulting A1.

# ── Codebase memory (framework-level token-saving code-graph layer) ────────
# CODEBASE_MEMORY_ENABLED=false # true: framework starts codebase-memory-mcp at boot, indexes the
#                              # repo, injects a graph-derived architecture brief into CODE tasks, and
#                              # registers the `codebase` Terr (search_graph/trace_path/…) for deep
#                              # queries — so agents stop reading files to rediscover structure.
#                              # Needs `uvx` or `npx` on the server host. Live toggle in 设置 → 高级.
# CODEBASE_MEMORY_REPO=         # repo to scope/index; empty = server working directory.

# ── Server (read by `python -m autumn.server`) ─────────────────────────────
# AUTUMN_HOST=127.0.0.1        # bind address; set 0.0.0.0 to expose externally
# AUTUMN_PORT=8765
# AUTUMN_API_KEY=              # shared secret required on every request (except
#                             # /health). Unset = open (fine for localhost-only).
#                             # STRONGLY recommended whenever AUTUMN_HOST is not
#                             # 127.0.0.1: without it, anyone who can reach the
#                             # port can drive the agent and read all memory.
#                             # Clients send `Authorization: Bearer <key>` or
#                             # `X-API-Key: <key>`.
# AUTUMN_RELOAD=0              # 1 enables uvicorn auto-reload for development
# AUTUMN_ENV_FILE=.env         # which env file the server loads at startup
# AUTUMN_SKIP_INIT=0           # 1 skips Autumn() construction at startup (tests only)
# AUTUMN_BUILTIN_TERRS=        # safe: register always-safe domains at startup; all: + web

# ── Security hardening ─────────────────────────────────────────────────────
# AUTUMN_CORS_ORIGINS=*        # comma-separated allowed origins; default * (open).
#                             # Lock to known client origins when exposed, e.g.
#                             # https://app.example.com,http://localhost:5173
# AUTUMN_MAX_BODY_BYTES=4000000 # reject inbound request bodies larger than this
#                             # (cost-amplification / DoS guard). Default 4MB.
# AUTUMN_ALLOW_PRIVATE_NETWORK=0 # 1 disables the SSRF guard on web/knowledge
#                             # fetches so the model MAY reach private/loopback/
#                             # cloud-metadata hosts. Leave off unless you trust
#                             # the model and need to fetch internal URLs.
