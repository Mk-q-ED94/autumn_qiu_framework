# Autumn — environment configuration template.
# Copy to `.env` (gitignored) and fill in your provider details.
# Load with: AutumnConfig.from_env(env_file=".env")

# ── A1 (WP1 Tot — orchestration / routing) ─────────────────────────────────
A1_API_KEY=sk-...
A1_BASE_URL=https://api.openai.com
A1_MODEL=gpt-4o-mini
A1_PROTOCOL=openai             # openai | anthropic | hermes

# ── A2 (WP2 Tas — task execution) ──────────────────────────────────────────
A2_API_KEY=sk-...
A2_BASE_URL=https://api.anthropic.com
A2_MODEL=claude-sonnet-4-5
A2_PROTOCOL=anthropic

# ── A3 (WP3 Mis — mission / conversation) ──────────────────────────────────
A3_API_KEY=sk-...
A3_BASE_URL=https://api.openai.com
A3_MODEL=gpt-4o
A3_PROTOCOL=openai

# ── Pricing (optional, per slot — USD per 1,000,000 tokens) ────────────────
# Set these to your provider's published rates to get per-turn cost_usd in the
# workflow trace. Any slot can be priced; leave at 0 (omit) to skip.
# A1_INPUT_PRICE=0.15
# A1_OUTPUT_PRICE=0.60
# A2_INPUT_PRICE=3.00
# A2_OUTPUT_PRICE=15.00
# A3_INPUT_PRICE=2.50
# A3_OUTPUT_PRICE=10.00

# ── A4 (optional memory model — drives WP4, the memory-management workspace) ─
# A4 powers WP4: recall synthesis, consolidation summaries, and the
# recall/remember skills exposed via Autumn.add_memory_skills(). Without it,
# WP4 still does the mechanical work (forget/stats/pin) but consolidation 400s.
# Leave A4_API_KEY blank to disable; A4_MODEL must be set when A4_API_KEY is.
# A4_API_KEY=ollama
# A4_BASE_URL=http://localhost:11434
# A4_MODEL=llama3.1:8b
# A4_PROTOCOL=openai             # openai | anthropic | hermes

# ── Hermes (local model via Ollama — alternative to cloud providers) ───────
# A2_API_KEY=ollama
# A2_BASE_URL=http://localhost:11434
# A2_MODEL=hermes3:8b
# A2_PROTOCOL=hermes

# ── Embedding (optional; enables vector memory) ────────────────────────────
# EMBEDDING_API_KEY=sk-...
# EMBEDDING_BASE_URL=https://api.openai.com
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=1536

# ── Runtime ────────────────────────────────────────────────────────────────
STORAGE_DB_PATH=autumn_memory.db
HEADLESS_MISSION_ROUTE=auto    # auto | direct | convert
AUTO_INDEX=false               # true to auto-embed every history entry
VALIDATE_BEFORE_STREAM=true    # false to stream tokens live (checker becomes advisory)

# ── Behavior (optional — tunable knobs; defaults shown) ────────────────────
# AGENT_MAX_STEPS=10           # WP2 Agent ReAct iteration ceiling
# CHECKER_RETRIES=3            # Checker validate→correct attempts before giving up
# CONFIRM_THRESHOLD=0.75       # Selector confidence below which the user is asked
# HISTORY_LIMIT=50             # Per-area memory history entries retained
# MEMORY_DECAY_HALF_LIFE=0     # Seconds; entry importance halves each interval (0 = off).
#                              # When set, stale low-value memories are evicted before fresh ones.
# FOURD_MEMORY_ENABLED=false   # true: recall/evict rank by 4D activation score
# FOURD_PUSH_ON_TURN=false     # true: CONSTRAIN/REMIND memories auto-inject at turn start
# MOM1_ACCESS_ENABLED=true     # Mom2/Mom3 may request adjudicated Mom1 reads (A1 gates, A4 mediates).
#                              # false = kill switch: every request is denied without consulting A1.

# ── Server (read by `python -m autumn.server`) ─────────────────────────────
# AUTUMN_HOST=127.0.0.1        # bind address; set 0.0.0.0 to expose externally
# AUTUMN_PORT=8765
# AUTUMN_API_KEY=              # shared secret required on every request (except
#                             # /health). Unset = open (fine for localhost-only).
#                             # STRONGLY recommended whenever AUTUMN_HOST is not
#                             # 127.0.0.1: without it, anyone who can reach the
#                             # port can drive the agent and read all memory.
#                             # Clients send `Authorization: Bearer <key>` or
#                             # `X-API-Key: <key>`.
# AUTUMN_RELOAD=0              # 1 enables uvicorn auto-reload for development
# AUTUMN_ENV_FILE=.env         # which env file the server loads at startup
# AUTUMN_SKIP_INIT=0           # 1 skips Autumn() construction at startup (tests only)
# AUTUMN_BUILTIN_TERRS=        # safe: register always-safe domains at startup; all: + web
