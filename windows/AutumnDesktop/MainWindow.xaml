<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="AutumnDesktop.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    Title="Autumn 秋">

    <Grid>
        <muxc:NavigationView
            x:Name="Nav"
            PaneDisplayMode="Left"
            OpenPaneLength="240"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            Background="Transparent"
            SelectionChanged="Nav_SelectionChanged">

            <!-- Brand mark — the WinUI counterpart of the macOS sidebar logo. -->
            <muxc:NavigationView.PaneHeader>
                <StackPanel Orientation="Horizontal" Spacing="10" Padding="4,10,4,10">
                    <Border Width="30" Height="30" CornerRadius="9"
                            Background="{StaticResource AutumnBrandGradientBrush}">
                        <TextBlock Text="秋" Foreground="White" FontSize="16" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Autumn" FontWeight="SemiBold" FontSize="14" />
                        <TextBlock Text="多模型协作工作台" FontSize="11"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </StackPanel>
            </muxc:NavigationView.PaneHeader>

            <muxc:NavigationView.MenuItems>
                <muxc:NavigationViewItem Content="协作" Tag="Chat">
                    <muxc:NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8BD;" />
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
                <muxc:NavigationViewItem Content="记忆" Tag="Memory">
                    <muxc:NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE81C;" />
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
            </muxc:NavigationView.MenuItems>

            <muxc:NavigationView.FooterMenuItems>
                <muxc:NavigationViewItem Content="设置" Tag="Settings">
                    <muxc:NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;" />
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
            </muxc:NavigationView.FooterMenuItems>

            <Frame x:Name="ContentFrame" />
        </muxc:NavigationView>
    </Grid>
</Window>
