<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="AutumnDesktop.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    Title="Autumn 秋">

    <Grid>
        <muxc:NavigationView
            x:Name="Nav"
            PaneDisplayMode="Left"
            OpenPaneLength="240"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            Background="Transparent"
            SelectionChanged="Nav_SelectionChanged">

            <!-- Brand mark — clay-gradient rounded logotype matching the macOS sidebar. -->
            <muxc:NavigationView.PaneHeader>
                <StackPanel Orientation="Horizontal" Spacing="10" Padding="4,12,4,12">
                    <Border Width="30" Height="30" CornerRadius="9"
                            Background="{StaticResource AutumnBrandGradientBrush}">
                        <TextBlock Text="秋" Foreground="White" FontSize="16" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Autumn" FontWeight="SemiBold" FontSize="14" />
                        <TextBlock Text="多模型协作工作台" FontSize="11"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </StackPanel>
            </muxc:NavigationView.PaneHeader>

            <muxc:NavigationView.MenuItems>
                <muxc:NavigationViewItem Content="协作" Tag="Chat">
                    <muxc:NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8BD;" />
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
                <muxc:NavigationViewItem Content="记忆" Tag="Memory">
                    <muxc:NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE81C;" />
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
            </muxc:NavigationView.MenuItems>

            <muxc:NavigationView.FooterMenuItems>
                <muxc:NavigationViewItem Content="设置" Tag="Settings">
                    <muxc:NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;" />
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
            </muxc:NavigationView.FooterMenuItems>

            <!-- Pane footer — agent slot indicators + version label.
                 Mirrors the macOS sidebar footer status row. -->
            <muxc:NavigationView.PaneFooter>
                <StackPanel Padding="16,8,16,16" Spacing="6">
                    <Rectangle Height="1" Fill="{ThemeResource CardStrokeColorDefaultBrush}"
                               Margin="0,0,0,4" />
                    <!-- A1 / A2 / A3 / A4 configured-state dots -->
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="4" x:Name="A1Dot">
                            <Ellipse Width="6" Height="6" VerticalAlignment="Center"
                                     Fill="{StaticResource AutumnClayBrush}" Opacity="0.5" />
                            <TextBlock Text="A1" FontSize="10"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <Ellipse Width="6" Height="6" VerticalAlignment="Center"
                                     Fill="{StaticResource AutumnWarningBrush}" Opacity="0.5" />
                            <TextBlock Text="A2" FontSize="10"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <Ellipse Width="6" Height="6" VerticalAlignment="Center"
                                     Fill="{StaticResource AutumnSlateBrush}" Opacity="0.5" />
                            <TextBlock Text="A3" FontSize="10"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="4" Opacity="0.4">
                            <Ellipse Width="6" Height="6" VerticalAlignment="Center"
                                     Fill="{StaticResource AutumnMemoryBrush}" />
                            <TextBlock Text="A4" FontSize="10"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        </StackPanel>
                    </StackPanel>
                    <TextBlock Text="Paper &amp; Clay · v0.2.2" FontSize="9"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                </StackPanel>
            </muxc:NavigationView.PaneFooter>

            <Frame x:Name="ContentFrame" />
        </muxc:NavigationView>
    </Grid>
</Window>
