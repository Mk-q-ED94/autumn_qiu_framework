<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="AutumnDesktop.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:common="using:AutumnDesktop.Common">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!-- ══ Theme-adaptive tokens ════════════════════════════════════════
                 The accent is retinted to clay app-wide by overriding the system
                 accent brushes per theme, so AccentButtonStyle, the NavigationView
                 selection indicator, accent text, etc. all follow Paper & Clay
                 without per-control work. The page warmth wash + neutral surface
                 tints flip with light/dark too. -->
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <!-- Accent → clay -->
                    <Color x:Key="SystemAccentColor">#CC6645</Color>
                    <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="#CC6645" />
                    <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="#E6CC6645" />
                    <SolidColorBrush x:Key="AccentFillColorTertiaryBrush" Color="#CCCC6645" />
                    <SolidColorBrush x:Key="AccentTextFillColorPrimaryBrush" Color="#9C452E" />
                    <SolidColorBrush x:Key="AccentTextFillColorSecondaryBrush" Color="#9C452E" />
                    <SolidColorBrush x:Key="AccentTextFillColorTertiaryBrush" Color="#CC6645" />

                    <!-- Sidebar — warm paper, distinct from Mica content area -->
                    <SolidColorBrush x:Key="AutumnSidebarBrush" Color="#F3EDE7" />

                    <!-- Paper & Clay surfaces -->
                    <SolidColorBrush x:Key="AutumnSurfaceElevatedBrush" Color="#0A000000" />
                    <SolidColorBrush x:Key="AutumnAssistantBubbleBrush" Color="#09000000" />
                    <SolidColorBrush x:Key="AutumnAssistantBubbleStrokeBrush" Color="#16000000" />
                    <LinearGradientBrush x:Key="AutumnPageWarmthBrush" StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#10CC6645" Offset="0.0" />
                        <GradientStop Color="#06C29E73" Offset="0.45" />
                        <GradientStop Color="#00FFFFFF" Offset="1.0" />
                    </LinearGradientBrush>
                </ResourceDictionary>

                <ResourceDictionary x:Key="Dark">
                    <!-- Accent → clay (lifted a touch for dark surfaces) -->
                    <Color x:Key="SystemAccentColor">#D67A55</Color>
                    <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="#D67A55" />
                    <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="#E6D67A55" />
                    <SolidColorBrush x:Key="AccentFillColorTertiaryBrush" Color="#CCD67A55" />
                    <SolidColorBrush x:Key="AccentTextFillColorPrimaryBrush" Color="#E8A07E" />
                    <SolidColorBrush x:Key="AccentTextFillColorSecondaryBrush" Color="#E8A07E" />
                    <SolidColorBrush x:Key="AccentTextFillColorTertiaryBrush" Color="#D67A55" />

                    <!-- Sidebar — warm dark, distinct from Mica content area -->
                    <SolidColorBrush x:Key="AutumnSidebarBrush" Color="#1C1814" />

                    <!-- Paper & Clay surfaces -->
                    <SolidColorBrush x:Key="AutumnSurfaceElevatedBrush" Color="#14FFFFFF" />
                    <SolidColorBrush x:Key="AutumnAssistantBubbleBrush" Color="#10FFFFFF" />
                    <SolidColorBrush x:Key="AutumnAssistantBubbleStrokeBrush" Color="#1FFFFFFF" />
                    <LinearGradientBrush x:Key="AutumnPageWarmthBrush" StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1FCC6645" Offset="0.0" />
                        <GradientStop Color="#0AC29E73" Offset="0.45" />
                        <GradientStop Color="#00000000" Offset="1.0" />
                    </LinearGradientBrush>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <!-- ══ Value converters ═══════════════════════════════════════════ -->
            <common:NotNullToBoolConverter x:Key="NotNullToBool" />
            <common:NotNullToVisibilityConverter x:Key="NotNullToVisibility" />
            <common:BoolToVisibilityConverter x:Key="BoolToVisibility" />
            <common:WorkspaceToBrushConverter x:Key="WorkspaceToBrush" />
            <common:StatusToBrushConverter x:Key="StatusToBrush" />

            <!-- ══ Global control polish ════════════════════════════════════════
                 Rounded corners on all text inputs so they read as the app's own
                 controls rather than stock Fluent. The focus underline remains but
                 is de-emphasised by keeping BorderThickness at 1 rather than the
                 default thick bottom stroke the Fluent template uses. -->
            <Style TargetType="TextBox" BasedOn="{StaticResource DefaultTextBoxStyle}">
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="BorderThickness" Value="1" />
            </Style>
            <Style TargetType="PasswordBox" BasedOn="{StaticResource DefaultPasswordBoxStyle}">
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="BorderThickness" Value="1" />
            </Style>
            <Style TargetType="ComboBox" BasedOn="{StaticResource DefaultComboBoxStyle}">
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="BorderThickness" Value="1" />
            </Style>

            <!-- ══ Brand spine — clay palette (theme-independent) ═════════════ -->
            <SolidColorBrush x:Key="AutumnClayBrush" Color="#CC6645" />
            <SolidColorBrush x:Key="AutumnClayDeepBrush" Color="#9C452E" />
            <SolidColorBrush x:Key="AutumnSandBrush" Color="#C29E73" />
            <SolidColorBrush x:Key="AutumnSageBrush" Color="#708F73" />
            <SolidColorBrush x:Key="AutumnSlateBrush" Color="#527A85" />
            <SolidColorBrush x:Key="AutumnMemoryBrush" Color="#82699E" />
            <SolidColorBrush x:Key="AutumnSuccessBrush" Color="#5C996B" />
            <SolidColorBrush x:Key="AutumnWarningBrush" Color="#D69442" />
            <SolidColorBrush x:Key="AutumnDangerBrush" Color="#CC544D" />

            <!-- Chat bubble tints — user turns carry a hint of clay. -->
            <SolidColorBrush x:Key="AutumnUserBubbleBrush" Color="#1FCC6645" />
            <SolidColorBrush x:Key="AutumnUserBubbleStrokeBrush" Color="#4DCC6645" />

            <!-- Brand gradient — claydeep → clay, used by primary actions + logo. -->
            <LinearGradientBrush x:Key="AutumnBrandGradientBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#9C452E" Offset="0.0" />
                <GradientStop Color="#CC6645" Offset="1.0" />
            </LinearGradientBrush>

            <!-- ══ Radius tokens (match Tokens.swift) ════════════════════════ -->
            <x:Double x:Key="AutumnRadiusXSValue">4</x:Double>
            <x:Double x:Key="AutumnRadiusSMValue">7</x:Double>
            <x:Double x:Key="AutumnRadiusMDValue">11</x:Double>
            <x:Double x:Key="AutumnRadiusLGValue">16</x:Double>
            <CornerRadius x:Key="AutumnRadiusXS">4</CornerRadius>
            <CornerRadius x:Key="AutumnRadiusSM">7</CornerRadius>
            <CornerRadius x:Key="AutumnRadiusMD">11</CornerRadius>
            <CornerRadius x:Key="AutumnRadiusLG">16</CornerRadius>
            <CornerRadius x:Key="AutumnRadiusPill">999</CornerRadius>
            <CornerRadius x:Key="AutumnCardRadius">11</CornerRadius>

            <!-- ══ Component styles ══════════════════════════════════════════ -->

            <!-- Card surface — uses the app's own surface brush rather than the
                 system CardBackground so it reads as warm paper, not Windows settings. -->
            <Style x:Key="AutumnCardStyle" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource AutumnSurfaceElevatedBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="11" />
                <Setter Property="Padding" Value="16" />
            </Style>

            <!-- Section heading inside a card. -->
            <Style x:Key="AutumnSectionHeaderStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="15" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>

            <!-- Quiet caption / helper text. -->
            <Style x:Key="AutumnCaptionStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <!-- Ghost / outline action — hairline border, accent foreground, no fill. -->
            <Style x:Key="AutumnGhostButtonStyle" TargetType="Button">
                <Setter Property="Foreground" Value="{StaticResource AutumnClayBrush}" />
                <Setter Property="Padding" Value="14,7" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="MinWidth" Value="0" />
                <Setter Property="UseSystemFocusVisuals" Value="True" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Grid x:Name="Root"
                                  CornerRadius="7"
                                  Padding="{TemplateBinding Padding}">
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal" />
                                        <VisualState x:Name="PointerOver">
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="Root"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 To="0.8" Duration="0:0:0.1" />
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="Root"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 To="0.6" Duration="0:0:0.05" />
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Disabled">
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="Root"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 To="0.35" Duration="0" />
                                            </Storyboard>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                                <!-- Hairline border, no fill -->
                                <Border CornerRadius="7"
                                        BorderBrush="{StaticResource AutumnClayBrush}"
                                        BorderThickness="1" />
                                <ContentPresenter x:Name="ContentPresenter"
                                                  Content="{TemplateBinding Content}"
                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                  Foreground="{TemplateBinding Foreground}"
                                                  HorizontalContentAlignment="Center"
                                                  VerticalContentAlignment="Center"
                                                  AutomationProperties.AccessibilityView="Raw" />
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Primary action — brand-gradient fill, white label, opacity states.
                 A self-contained template keeps the gradient on every visual state
                 (the default accent template would swap in flat state brushes). -->
            <Style x:Key="AutumnPrimaryButtonStyle" TargetType="Button">
                <Setter Property="Foreground" Value="White" />
                <Setter Property="Padding" Value="14,8" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="HorizontalAlignment" Value="Left" />
                <Setter Property="MinWidth" Value="0" />
                <Setter Property="UseSystemFocusVisuals" Value="True" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Grid x:Name="Root"
                                  Background="{StaticResource AutumnBrandGradientBrush}"
                                  CornerRadius="7"
                                  Padding="{TemplateBinding Padding}">
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal" />
                                        <VisualState x:Name="PointerOver">
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="Root"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 To="0.92" Duration="0:0:0.1" />
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="Root"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 To="0.82" Duration="0:0:0.05" />
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Disabled">
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="Root"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 To="0.4" Duration="0" />
                                            </Storyboard>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                                <ContentPresenter x:Name="ContentPresenter"
                                                  Content="{TemplateBinding Content}"
                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                  Foreground="{TemplateBinding Foreground}"
                                                  HorizontalContentAlignment="Center"
                                                  VerticalContentAlignment="Center"
                                                  AutomationProperties.AccessibilityView="Raw" />
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
