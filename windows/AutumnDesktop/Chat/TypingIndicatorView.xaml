<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="AutumnDesktop.Chat.TypingIndicatorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Height="18">

    <!-- Three dots animate sequentially: one bright dot cycles left-to-right.
         Timer runs only while the control is in the visual tree (Loaded/Unloaded). -->
    <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
        <Ellipse x:Name="Dot0" Width="5" Height="5"
                 Fill="{ThemeResource TextFillColorSecondaryBrush}" />
        <Ellipse x:Name="Dot1" Width="5" Height="5"
                 Fill="{ThemeResource TextFillColorSecondaryBrush}" Opacity="0.3" />
        <Ellipse x:Name="Dot2" Width="5" Height="5"
                 Fill="{ThemeResource TextFillColorSecondaryBrush}" Opacity="0.3" />
    </StackPanel>
</UserControl>
