<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AutumnDesktop.Chat.ChatPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AutumnDesktop.Chat"
    xmlns:models="using:AutumnDesktop.Models"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">

    <Page.Resources>
        <!-- ── User turn — right-aligned, clay-tinted bubble ──────────────── -->
        <DataTemplate x:Key="UserBubbleTemplate" x:DataType="local:ChatMessage">
            <Grid Margin="0,4" HorizontalAlignment="Right">
                <Border MaxWidth="560" Padding="12,8" CornerRadius="16"
                        Background="{StaticResource AutumnUserBubbleBrush}"
                        BorderBrush="{StaticResource AutumnUserBubbleStrokeBrush}"
                        BorderThickness="1">
                    <TextBlock Text="{x:Bind Text, Mode=OneWay}" TextWrapping="Wrap"
                               IsTextSelectionEnabled="True" />
                </Border>
            </Grid>
        </DataTemplate>

        <!-- ── Assistant turn — left-aligned, neutral bubble + workflow trace ─ -->
        <DataTemplate x:Key="AssistantBubbleTemplate" x:DataType="local:ChatMessage">
            <StackPanel Margin="0,4" HorizontalAlignment="Left" Spacing="6">
                <Border MaxWidth="560" Padding="12,8" CornerRadius="16"
                        HorizontalAlignment="Left"
                        Background="{ThemeResource AutumnAssistantBubbleBrush}"
                        BorderBrush="{ThemeResource AutumnAssistantBubbleStrokeBrush}"
                        BorderThickness="1">
                    <TextBlock Text="{x:Bind Text, Mode=OneWay}" TextWrapping="Wrap"
                               IsTextSelectionEnabled="True" />
                </Border>

                <muxc:Expander Visibility="{x:Bind TraceVisibility, Mode=OneWay}"
                               HorizontalAlignment="Stretch"
                               Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                               BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                               CornerRadius="11">
                    <muxc:Expander.Header>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                                     Fill="{StaticResource AutumnClayBrush}" />
                            <TextBlock Text="协作路径" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <TextBlock Text="{x:Bind Trace.SummaryLine, Mode=OneWay}" FontSize="11"
                                       VerticalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </muxc:Expander.Header>

                    <ItemsControl ItemsSource="{x:Bind Trace.Stages, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:WorkflowStage">
                                <Grid ColumnSpacing="10" Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="4" CornerRadius="2"
                                            Background="{x:Bind Workspace, Converter={StaticResource WorkspaceToBrush}}" />
                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{x:Bind WorkspaceLabel}" FontSize="10"
                                                       FontWeight="SemiBold" VerticalAlignment="Center"
                                                       Foreground="{x:Bind Workspace, Converter={StaticResource WorkspaceToBrush}}" />
                                            <TextBlock Text="{x:Bind Title}" FontWeight="SemiBold" FontSize="13" />
                                        </StackPanel>
                                        <TextBlock Text="{x:Bind Detail}" Visibility="{x:Bind DetailVisibility}"
                                                   TextWrapping="Wrap" FontSize="12"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Text="{x:Bind MetaLine}" Visibility="{x:Bind MetaVisibility}"
                                                   FontSize="11" FontFamily="Consolas"
                                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </muxc:Expander>
            </StackPanel>
        </DataTemplate>

        <local:ChatBubbleTemplateSelector x:Key="BubbleSelector"
                                          UserTemplate="{StaticResource UserBubbleTemplate}"
                                          AssistantTemplate="{StaticResource AssistantBubbleTemplate}" />
    </Page.Resources>

    <Grid Background="{ThemeResource AutumnPageWarmthBrush}" Padding="20,16,20,16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Message list -->
        <ScrollViewer Grid.Row="0" x:Name="MessageScroller" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{x:Bind ViewModel.Messages}"
                          ItemTemplateSelector="{StaticResource BubbleSelector}" />
        </ScrollViewer>

        <!-- Empty state -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Spacing="14" MaxWidth="400"
                    Visibility="{x:Bind ViewModel.HasMessages, Mode=OneWay, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
            <Border Width="72" Height="72" CornerRadius="20" HorizontalAlignment="Center"
                    Background="{StaticResource AutumnBrandGradientBrush}">
                <TextBlock Text="秋" FontSize="34" FontWeight="SemiBold" Foreground="White"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <TextBlock Text="开始协作" FontSize="20" FontWeight="SemiBold" HorizontalAlignment="Center" />
            <TextBlock Text="向 Autumn 提问或下达任务，A1 / A2 / A3 将协同编排、执行并作答。"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextWrapping="Wrap" TextAlignment="Center" HorizontalAlignment="Center" />
        </StackPanel>

        <!-- Inline error -->
        <muxc:InfoBar
            Grid.Row="1"
            IsOpen="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, Converter={StaticResource NotNullToBool}}"
            Severity="Error"
            Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}" />

        <!-- Composer -->
        <Grid Grid.Row="2" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox
                Grid.Column="0"
                x:Name="InputBox"
                PlaceholderText="输入消息…  (Enter 发送，Shift+Enter 换行)"
                Text="{x:Bind ViewModel.Input, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                AcceptsReturn="True"
                TextWrapping="Wrap"
                MinHeight="44"
                MaxHeight="140"
                CornerRadius="11"
                VerticalAlignment="Bottom"
                KeyDown="InputBox_KeyDown" />

            <!-- Send / Stop occupy the same cell, toggled by IsBusy. -->
            <Grid Grid.Column="1" VerticalAlignment="Bottom">
                <Button
                    Style="{StaticResource AutumnPrimaryButtonStyle}"
                    Width="44" Height="36" Padding="0"
                    ToolTipService.ToolTip="发送"
                    Command="{x:Bind ViewModel.SendCommand}"
                    Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                    <FontIcon Glyph="&#xE724;" FontSize="16" Foreground="White" />
                </Button>
                <Button
                    Width="44" Height="36" Padding="0" CornerRadius="7"
                    Background="{StaticResource AutumnDangerBrush}" Foreground="White"
                    ToolTipService.ToolTip="停止"
                    Command="{x:Bind ViewModel.CancelCommand}"
                    Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                    <FontIcon Glyph="&#xE711;" FontSize="14" Foreground="White" />
                </Button>
            </Grid>

            <Button Grid.Column="2" Height="36" VerticalAlignment="Bottom"
                    Content="结束会话" Command="{x:Bind ViewModel.EndSessionCommand}" />
        </Grid>
    </Grid>
</Page>
