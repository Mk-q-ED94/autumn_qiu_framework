<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="AutumnDesktop.DesignSystem.AutumnBadge"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    HorizontalAlignment="Left"
    VerticalAlignment="Center">

    <!-- Pill badge — the WinUI counterpart of macOS AutumnBadge. Icon + label on
         a tone-tinted capsule; colours are applied from code-behind by Tone. -->
    <Border x:Name="Root"
            CornerRadius="999"
            Padding="8,3"
            VerticalAlignment="Center">
        <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
            <FontIcon x:Name="IconElement"
                      FontSize="11"
                      Visibility="Collapsed"
                      VerticalAlignment="Center" />
            <TextBlock x:Name="LabelElement"
                       FontSize="12"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center" />
        </StackPanel>
    </Border>
</UserControl>
